# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit real secrets.

SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://sjokoloko:sjokoloko_dev@localhost:5432/sjokoloko_db

# ── Vipps MobilePay ePayment ──────────────────────────────────────────────
# Test environment by default; switch VIPPS_BASE_URL to https://api.vipps.no
# for production. All four credential values come from the Vipps developer
# portal (https://portal.vipps.no/).
VIPPS_BASE_URL=https://apitest.vipps.no
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MERCHANT_SERIAL_NUMBER=
VIPPS_SYSTEM_NAME=sjokoloko
VIPPS_SYSTEM_VERSION=1.0.0
VIPPS_SYSTEM_PLUGIN_NAME=sjokoloko-vipps
VIPPS_SYSTEM_PLUGIN_VERSION=1.0.0

# URL the user is redirected back to after paying (Next.js storefront).
VIPPS_RETURN_URL_BASE=http://localhost:3000/kasse/retur

# Public HTTPS URL Vipps will POST webhooks to. In dev, use ngrok or
# cloudflared to expose your local Django dev server. Pass this same URL to
# `python manage.py vipps_register_webhooks`.
VIPPS_WEBHOOK_URL=

# Prefix used in the merchant `reference` field. Lowercase per Vipps docs.
VIPPS_REFERENCE_PREFIX=sl

# Outbound HTTP timeout for Vipps calls (seconds).
VIPPS_HTTP_TIMEOUT=4

# Log level for the apps.payments_vipps logger.
VIPPS_LOG_LEVEL=INFO
